# Python Compiled Files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
ENV/
env/

# PyInstaller / Packaging build outputs (Avoid uploading 100MB+ binaries to git)
build/
dist/
*.spec

# Portable binaries (Avoid uploading 400MB+ FFmpeg/FFprobe binaries)
bin/

# Local databases and user-specific history data
data/*.db
data/history.db

# Editors and IDEs
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS-specific system files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
